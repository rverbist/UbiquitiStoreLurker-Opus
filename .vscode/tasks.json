{
  "version": "2.0.0",
  "presentation": {
    "echo": true,
    "reveal": "always",
    "focus": true,
    "panel": "shared",
    "showReuseMessage": false,
    "clear": false
  },
  "tasks": [
    // ── RUN ───────────────────────────────────────────────────────────────────────
    {
      "label": "Run Web App",
      "type": "shell",
      "command": "dotnet run --project UniFiStoreWatcher.Web/UniFiStoreWatcher.Web.csproj",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "line": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting UniFiStoreWatcher.*$",
          "endsPattern": "^.*Now listening on:.*$"
        }
      }
    },
    // ── BUILD ─────────────────────────────────────────────────────────────────────
    {
      "label": "Restore",
      "type": "shell",
      "command": "dotnet restore UniFiStoreWatcher.slnx",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "dotnet build UniFiStoreWatcher.slnx",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Rebuild",
      "type": "shell",
      "command": "dotnet build UniFiStoreWatcher.slnx --no-incremental",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "dotnet clean UniFiStoreWatcher.slnx",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    }
  ]
}
