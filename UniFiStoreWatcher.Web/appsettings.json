{
  "ConnectionStrings": {
    "UniFiStoreWatcher": "Data Source=UniFiStoreWatcher.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Polling": {
    "MinIntervalSeconds": 30,
    "MaxIntervalSeconds": 90,
    "SchedulerScanIntervalSeconds": 10,
    "ChannelCapacity": 100,
    "BrowserUserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
    "MinRequestGapMs": 12000,
    "JitterPercent": 30
  }
}
