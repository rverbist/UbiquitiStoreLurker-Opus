# Copy this file to .env (for local development) or .env.Production (for Docker deployment).
# Never commit real secrets. This file is safe to commit.

# ASPNETCORE_HTTP_PORTS is only needed in production (Docker).
# In development, the port is controlled by launchSettings.json.
ASPNETCORE_ENVIRONMENT=<Development|Production>
# ASPNETCORE_HTTP_PORTS=8080   # uncomment for .env.Production only
ConnectionStrings__UniFiStoreWatch-db=Server=<host>;Database=<database>;User Id=<username>;Password=<password>;TrustServerCertificate=True
