{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eu-ai-act-en_enhanced_v2.schema.json",
  "title": "EU AI Act Enhanced Document v2",
  "description": "Schema for the AI-consumable enhanced representation of EU AI Act (Regulation 2024/1689). Version 2.1 includes LLM-assisted annotation enhancements: summaryText, keywords, penaltyExposure, ambiguitySignal, temporalScope, and verified/corrected normMetadata and structuralMetadata.",
  "type": "object",
  "required": [
    "metadata",
    "definitions",
    "chapters",
    "annexes",
    "recitals"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Document-level metadata including version info, node counts, penalty structure, and indices.",
      "required": [
        "scanDate",
        "regulation",
        "totalNodes",
        "totalDefinitions",
        "nodesByType",
        "penaltyStructure",
        "indices",
        "version",
        "mergeDate",
        "batchesApplied"
      ],
      "properties": {
        "scanDate": {
          "type": "string",
          "format": "date-time",
          "description": "When the source regulation was originally parsed."
        },
        "regulation": {
          "type": "string",
          "description": "Regulation identifier. e.g. 'EU AI Act (Regulation 2024/1689)'"
        },
        "totalNodes": {
          "type": "integer",
          "description": "Total number of nodes across all sections."
        },
        "totalDefinitions": {
          "type": "integer",
          "description": "Number of definitions in Article 3."
        },
        "version": {
          "type": "string",
          "description": "Schema/document version. e.g. '2.1'"
        },
        "mergeDate": {
          "type": "string",
          "format": "date-time",
          "description": "When enhancement batches were merged into this file."
        },
        "batchesApplied": {
          "type": "integer",
          "description": "Number of enhancement batches merged."
        },
        "nodesByType": {
          "type": "object",
          "description": "Count of nodes per type.",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "penaltyStructure": {
          "type": "object",
          "description": "Penalty tier definitions from Article 99.",
          "properties": {
            "tiers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "level": {
                    "type": "string",
                    "enum": [
                      "maximum",
                      "high",
                      "medium",
                      "low"
                    ]
                  },
                  "amount": {
                    "type": "integer",
                    "description": "Maximum fine amount in EUR."
                  },
                  "currency": {
                    "type": "string"
                  },
                  "alternativeFormula": {
                    "type": "string",
                    "description": "Percentage-of-turnover alternative."
                  },
                  "description": {
                    "type": "string"
                  },
                  "appliesTo": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Article anchors this tier applies to."
                  }
                }
              }
            }
          }
        },
        "indices": {
          "type": "object",
          "description": "Inverted indices for terminology, obligation verbs, and actor roles. Each index maps a term to an array of node anchors.",
          "properties": {
            "terminology": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "terminology-keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "obligation": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "obligation-keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actor": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "actor-keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "definitions": {
      "type": "array",
      "description": "Article 3 definitions. These are reference-only entries, not operative nodes.",
      "items": {
        "type": "object",
        "required": [
          "anchor",
          "label",
          "description",
          "line"
        ],
        "properties": {
          "anchor": {
            "type": "string",
            "pattern": "^definition-\\d+"
          },
          "label": {
            "type": "string",
            "description": "The defined term."
          },
          "description": {
            "type": "string",
            "description": "The definition text."
          },
          "line": {
            "type": "integer",
            "description": "Line number in eu-ai-act-en.md."
          },
          "referenced": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Anchors of nodes that reference this definition."
          }
        }
      }
    },
    "chapters": {
      "type": "array",
      "description": "All chapter, article, paragraph, and point nodes. This is the primary operative content.",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "annexes": {
      "type": "array",
      "description": "Annex nodes with full enhancement metadata.",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "recitals": {
      "type": "array",
      "description": "Recital nodes. Non-operative but provide interpretive context.",
      "items": {
        "$ref": "#/$defs/recitalNode"
      }
    }
  },
  "$defs": {
    "derivedFrom": {
      "type": "object",
      "description": "Provenance metadata for AI-assisted annotations. All LLM-generated fields must include this.",
      "required": [
        "method",
        "ruleVersion"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "regex-v1",
            "deterministic-regex-v1",
            "regex-extractor-v1",
            "llm-assisted-v1",
            "manual",
            "manual-verification"
          ],
          "description": "How this annotation was generated."
        },
        "ruleVersion": {
          "type": "string",
          "description": "Version of the extraction/enhancement rules."
        },
        "ruleIds": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "description": "Which specific rules produced this annotation."
        },
        "sourceLines": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Line numbers in eu-ai-act-en.md that were analyzed."
        },
        "modalVerb": {
          "type": [
            "string",
            "null"
          ],
          "description": "The modal verb that triggered this annotation (shall, may, etc.)."
        },
        "note": {
          "type": "string",
          "description": "Optional human-readable note about the derivation."
        },
        "notes": {
          "type": "string",
          "description": "Optional human-readable notes about the derivation."
        }
      }
    },
    "ambiguitySignal": {
      "type": [
        "object",
        "null"
      ],
      "description": "Signals how clear or ambiguous a provision is. Critical for confidence calibration in compliance assessments.",
      "required": [
        "level",
        "reason",
        "derivedFrom"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "clear",
            "interpretive",
            "vague",
            "delegated"
          ],
          "description": "clear: fully specified. interpretive: reasonable disagreement possible. vague: intentionally broad. delegated: deferred to implementing/delegated acts."
        },
        "reason": {
          "type": "string",
          "description": "Why this level was assigned."
        },
        "delegatedTo": {
          "type": [
            "string",
            "array",
            "null"
          ],
          "description": "If delegated, the anchor(s) or body to which specifics are deferred.",
          "items": {
            "type": "string"
          }
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        }
      }
    },
    "temporalScope": {
      "type": [
        "object",
        "null"
      ],
      "description": "When this provision becomes applicable, per Article 113 transitional provisions.",
      "required": [
        "applicableFrom",
        "applicableFromBasis",
        "derivedFrom"
      ],
      "properties": {
        "applicableFrom": {
          "type": "string",
          "format": "date",
          "description": "ISO date when provision takes effect."
        },
        "applicableFromBasis": {
          "type": "string",
          "description": "Anchor of the Article 113 paragraph that establishes this date."
        },
        "transitionalProvisions": {
          "type": [
            "object",
            "string",
            "null"
          ],
          "description": "Any transitional arrangement details."
        },
        "notes": {
          "type": "string",
          "description": "Optional clarification."
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        }
      }
    },
    "penaltyExposure": {
      "type": [
        "object",
        "null"
      ],
      "description": "Penalty tier and traceability chain linking this provision to Article 99 fines.",
      "required": [
        "tier",
        "traceability",
        "derivedFrom"
      ],
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "maximum",
            "high",
            "medium",
            "low",
            "none"
          ],
          "description": "maximum: \u20ac35M/7%. high: \u20ac15M/3%. medium: \u20ac7.5M/1%. low: lesser. none: no direct penalty."
        },
        "maxAmount": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum fine amount in EUR."
        },
        "alternativeFormula": {
          "type": [
            "string",
            "null"
          ],
          "description": "Percentage-of-turnover alternative formula."
        },
        "traceability": {
          "type": "string",
          "description": "Chain from Article 99 \u2192 intermediate articles \u2192 this node."
        },
        "applicableArticles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Article anchors in the penalty chain."
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        }
      }
    },
    "normMetadata": {
      "type": [
        "object",
        "null"
      ],
      "description": "Normative classification of the provision. Identifies obligation type, affected actors, and conditions.",
      "properties": {
        "normType": {
          "type": "string",
          "enum": [
            "obligation",
            "prohibition",
            "permission",
            "exclusion",
            "savings-clause",
            "savings_clause",
            "delegation",
            "right",
            "definition",
            "exception",
            "provision",
            "specification",
            "applicability-condition",
            "application",
            "mixed",
            "reference"
          ],
          "description": "Primary normative classification."
        },
        "modalVerb": {
          "type": "string",
          "description": "The modal verb (shall, may, must, etc.)."
        },
        "obligatedActors": {
          "type": [
            "array",
            "null"
          ],
          "description": "Actors bearing the obligation. Can be strings or structured objects.",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "actor": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "jurisdiction": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "permittedActors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "actor": {
                "type": "string"
              },
              "confidence": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            }
          }
        },
        "beneficiaryActors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "actor": {
                "type": "string"
              },
              "confidence": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "jurisdiction": {
                "type": "string"
              }
            }
          }
        },
        "conditions": {
          "description": "Conditions, triggers, exceptions, and qualifiers. Structure varies by provision complexity \u2014 can be an object with named condition types, an array of condition entries, or null.",
          "type": [
            "object",
            "array",
            "null"
          ]
        },
        "normConditions": {
          "type": "object",
          "description": "Legacy simplified condition structure.",
          "properties": {
            "where": {
              "type": [
                "string",
                "null"
              ]
            },
            "unless": {
              "type": [
                "string",
                "null"
              ]
            },
            "when": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "applicability": {
          "type": [
            "object",
            "null"
          ],
          "description": "Detailed applicability metadata \u2014 risk levels, lifecycle phases, system types, actor scopes, sectors, etc. Structure varies significantly across provisions."
        },
        "secondaryObligations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "actor": {
                "type": "string"
              },
              "obligation": {
                "type": "string"
              },
              "exception": {
                "type": "string"
              }
            }
          }
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        },
        "contextType": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "obligation": {
          "type": [
            "string",
            "null"
          ]
        },
        "prohibition": {
          "type": "null"
        },
        "permission": {
          "type": "null"
        },
        "obligationType": {
          "type": "string"
        },
        "permissionType": {
          "type": "string"
        },
        "substantiveContent": {
          "type": "string"
        },
        "applicabilityPhase": {
          "type": "string"
        },
        "applicabilityScope": {
          "type": "string"
        },
        "applicableTo": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedProvisionsInPrincipal": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "referenceWithContext": {
      "type": "object",
      "description": "A cross-reference to another node with contextual information about the relationship.",
      "required": [
        "targetId",
        "contextType"
      ],
      "properties": {
        "targetId": {
          "type": "string",
          "description": "Anchor of the referenced node."
        },
        "contextType": {
          "type": "string",
          "enum": [
            "amendment",
            "applicability",
            "application",
            "assessment_requirement",
            "capability",
            "compliance",
            "compliance-facilitation",
            "compliance-pathway",
            "compliance-procedure",
            "compliance-requirement",
            "compliance-verification",
            "condition",
            "conditional-reference",
            "consequence",
            "coordination",
            "definition",
            "delegation",
            "derogation",
            "designation_rule",
            "enforcement",
            "exception",
            "exclusion",
            "governance-coordination",
            "implementation-support",
            "implementing_authority",
            "limitation",
            "mitigation",
            "modification",
            "normative_scope",
            "penalty",
            "procedural",
            "procedure",
            "qualification",
            "record-keeping",
            "reference",
            "requirement",
            "risk-reference",
            "savings-clause",
            "scope",
            "scope_expansion",
            "supplement",
            "timing-trigger",
            "trigger"
          ],
          "description": "The nature of the cross-reference relationship."
        },
        "context": {
          "type": "string",
          "description": "Human-readable description of the relationship."
        },
        "snippet": {
          "type": [
            "string",
            "null"
          ],
          "description": "Relevant text excerpt from the source."
        },
        "lineInSource": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Line number of the reference in source text."
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        }
      }
    },
    "structuralMetadata": {
      "type": "object",
      "description": "Article-level structural classification flags. Derived from regex extraction, verified/corrected by LLM enhancement pass.",
      "properties": {
        "hasObligations": {
          "type": "boolean"
        },
        "hasPermissions": {
          "type": "boolean"
        },
        "hasProhibitions": {
          "type": "boolean"
        },
        "hasPenalties": {
          "type": "boolean"
        },
        "hasTimeline": {
          "type": "boolean"
        },
        "hasDefinitions": {
          "type": "boolean"
        },
        "hasAnnexReference": {
          "type": "boolean"
        },
        "obligationVerbs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissionVerbs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applicableTo": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paragraphCount": {
          "type": "integer"
        },
        "subparagraphCount": {
          "type": "integer"
        },
        "isOperative": {
          "type": "boolean"
        },
        "isNormative": {
          "type": "boolean"
        },
        "isMandatory": {
          "type": "boolean"
        },
        "isPermissive": {
          "type": "boolean"
        },
        "isProhibitory": {
          "type": "boolean"
        },
        "isFinalProvision": {
          "type": "boolean"
        },
        "isAmendmentArticle": {
          "type": "boolean"
        },
        "isTechnicalRequirement": {
          "type": "boolean"
        },
        "isProceduralOrProcessual": {
          "type": "boolean"
        },
        "obligationBearing": {
          "type": "boolean"
        },
        "containsGuidance": {
          "type": "boolean"
        },
        "containsRequirements": {
          "type": "boolean"
        },
        "normativeType": {
          "type": "string"
        },
        "normativeStructure": {
          "type": "string"
        },
        "classification": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "scopeDescription": {
          "type": "string"
        },
        "permissionContext": {
          "type": "string"
        },
        "applicableActor": {
          "type": [
            "string",
            "null"
          ]
        },
        "applicableActors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applicableScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "annexesReferenced": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "regulationReference": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targetRegulation": {
          "type": "string"
        },
        "derivedFrom": {
          "$ref": "#/$defs/derivedFrom"
        }
      }
    },
    "graphMetrics": {
      "type": "object",
      "description": "Graph connectivity metrics for this node.",
      "properties": {
        "inDegree": {
          "type": "integer",
          "description": "Number of nodes referencing this node."
        },
        "outDegree": {
          "type": "integer",
          "description": "Number of nodes this node references."
        },
        "depth": {
          "type": "integer",
          "description": "Depth in the document hierarchy."
        },
        "transitiveReferences": {
          "type": "integer",
          "description": "Total transitive reference count."
        },
        "dependencyChainLength": {
          "type": "integer"
        },
        "dependencyChainLevel": {
          "type": "integer"
        }
      }
    },
    "node": {
      "type": "object",
      "description": "A structural node in the regulation (chapter, article, paragraph, point, annex, etc.).",
      "required": [
        "anchor",
        "type",
        "line",
        "endLine",
        "depth"
      ],
      "properties": {
        "anchor": {
          "type": "string",
          "description": "Unique node identifier. e.g. 'article-5-1-a'"
        },
        "type": {
          "type": "string",
          "enum": [
            "Chapter",
            "ChapterSection",
            "Article",
            "ArticleParagraph",
            "ArticlePoint",
            "Annex",
            "AnnexSection",
            "AnnexSectionParagraph",
            "AnnexParagraph",
            "AnnexPoint",
            "Recital"
          ],
          "description": "Node type in the document hierarchy."
        },
        "line": {
          "type": "integer",
          "description": "Start line in eu-ai-act-en.md (1-indexed)."
        },
        "endLine": {
          "type": "integer",
          "description": "End line in eu-ai-act-en.md (1-indexed, inclusive)."
        },
        "depth": {
          "type": "integer",
          "description": "Nesting depth (0 = top-level)."
        },
        "parent": {
          "type": [
            "string",
            "null"
          ],
          "description": "Anchor of parent node."
        },
        "children": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Anchors of direct child nodes."
        },
        "heading": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "fullTitle": {
          "type": "string"
        },
        "terminology": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Defined terms used in this node."
        },
        "referenced": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Nodes that reference this node (inbound)."
        },
        "referencing": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Nodes this node references (outbound)."
        },
        "referencesWithContext": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/referenceWithContext"
          },
          "description": "Typed cross-references with relationship context."
        },
        "graphMetrics": {
          "$ref": "#/$defs/graphMetrics"
        },
        "structuralMetadata": {
          "$ref": "#/$defs/structuralMetadata"
        },
        "normMetadata": {
          "$ref": "#/$defs/normMetadata"
        },
        "summaryText": {
          "type": [
            "string",
            "null"
          ],
          "description": "1-2 sentence plain-language summary. Article/Annex-level only."
        },
        "keywords": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "description": "Thematic keywords for search/retrieval."
        },
        "ambiguitySignal": {
          "$ref": "#/$defs/ambiguitySignal"
        },
        "temporalScope": {
          "$ref": "#/$defs/temporalScope"
        },
        "penaltyExposure": {
          "$ref": "#/$defs/penaltyExposure"
        }
      }
    },
    "recitalNode": {
      "type": "object",
      "description": "A recital node. Non-operative (no normMetadata, penaltyExposure, etc.).",
      "required": [
        "anchor",
        "type",
        "line",
        "endLine",
        "depth"
      ],
